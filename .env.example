# AutoVocaIndex environment configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# -- Firebase (required) ------------------------------------------------
# The app will not run without these. Create a Firebase project at
# https://console.firebase.google.com, add a Web App, and copy the values
# from Project settings > General > Your apps > SDK setup and configuration.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# -- Optional: AI definitions and grammar quizzes -----------------------
# Used by netlify/functions/get-definition.cjs and grammar-quiz.js.
# Without a key, AI-generated definitions and the grammar quiz modes are
# unavailable; everything else works. Get a key at
# https://console.anthropic.com
#ANTHROPIC_API_KEY=

# -- Optional: KRDict dictionary lookups --------------------------------
# Used by netlify/functions/get-krdict-api.cjs. Without a key, dictionary
# lookups are unavailable and lemma resolution falls back to its offline
# heuristics. Request a key at https://krdict.korean.go.kr/eng/openApi/openApiRegister
#KRDICT_API_KEY=

# -- Optional: Google Cloud text-to-speech audio ------------------------
# Used by netlify/functions/generate-tts.cjs. Requires a GCP service account
# with Text-to-Speech and Cloud Storage access, plus a GCS bucket where
# generated audio is cached. The values come from the service account's JSON
# key file; they are split into separate variables because the full JSON
# exceeds Netlify's 4KB per-variable limit.
# GCP_PRIVATE_KEY must be one line, with literal \n in place of newlines,
# exactly as it appears in the JSON key file.
#GCP_PROJECT_ID=
#GCP_CLIENT_EMAIL=
#GCP_PRIVATE_KEY_ID=
#GCP_PRIVATE_KEY=
#GCP_TTS_BUCKET=
